# opencorp — environment variables
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

# ── LLM provider (Mastra routes every model call through OpenRouter) ────────
OPENROUTER_API_KEY=

# ── Embeddings (used by the GTM Reddit scan clustering step) ───────────────
# Defaults to OpenAI's text-embedding-3-small if unset, but you can route
# through OpenRouter (model: "openai/text-embedding-3-small") or any
# OpenAI-compatible endpoint by overriding EMBED_BASE_URL.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=
# EMBED_BASE_URL=https://api.openai.com/v1

# ── GTM Reddit scan pipeline (src/mastra/workflows/gtm-redditscan.ts) ──────
# Required: Devvit-issued bearer JWT for oauth.reddit.com. Refresh by decoding
# ~/.devvit/token (the `accessToken` field inside the inner JSON) and writing
# the 800+ char JWT here. Without it, all Reddit API calls 401.
# REDDIT_BEARER=eyJhbGciOi...
# REDDIT_BEARER_UPDATED_AT=2026-07-07T18:37:02Z
#
# Throttle: queries-per-minute cap for the in-process token bucket. Reddit's
# free tier is 100 QPM; default 60 leaves headroom for search bursts.
# REDDIT_QPM_CAP=60
#
# User-Agent: Reddit requires a real identifier. Format required:
#   <platform>:<app>:<version> (by /u/<username>)
# REDDIT_USER_AGENT=opencorp:gtm-intel:v0.1 (by /u/yourname)

# SerperAPI — used for Google site:reddit.com queries (gtm-redditscan).
# Google ranks Reddit content by relevance, which is far better than Reddit's
# own /search for our use case. Free tier: 2,500 searches/month. Get a key at
# https://serper.dev
SERPER_API_KEY=

# ── Research tools ──────────────────────────────────────────────────────────
# Jina Reader — used by fetchPageTool to read product pages as clean markdown
JINA_API_KEY=
# Exa — used by searchWebTool for semantic web search
EXA_API_KEY=

# ── Trigger.dev (background jobs) ───────────────────────────────────────────
# Authenticates the Next.js app → Trigger.dev worker
TRIGGER_SECRET_KEY=

# ── Supabase (auth + database) ──────────────────────────────────────────────
# Browser-safe
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — keep secret
SUPABASE_SECRET_KEY=

# ── App config ──────────────────────────────────────────────────────────────
# Public origin of the deployed app (used for OAuth redirects, email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anon "bucket" user id is hardcoded in src/lib/supabase/server.ts. Auth is
# used only to capture email for future mailing; research sessions are shared.

# ── Umami (cloud) ───────────────────────────────────────────────────────────
# Cloud site ID and tracker host. Find both in your Umami dashboard under
# the website's "Tracking code" panel.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_HOST_URL=