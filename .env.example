# opencorp — environment variables
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

# ── LLM provider (Mastra routes every model call through OpenRouter) ────────
OPENROUTER_API_KEY=

# ── Research tools ──────────────────────────────────────────────────────────
# Jina Reader — used by fetchPageTool to read product pages as clean markdown
JINA_API_KEY=
# Exa — used by searchWebTool for semantic web search
EXA_API_KEY=

# ── Trigger.dev (background jobs) ───────────────────────────────────────────
# Authenticates the Next.js app → Trigger.dev worker
TRIGGER_SECRET_KEY=

# ── Supabase (auth + database) ──────────────────────────────────────────────
# Browser-safe
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — keep secret
SUPABASE_SECRET_KEY=

# ── App config ──────────────────────────────────────────────────────────────
# Public origin of the deployed app (used for OAuth redirects, email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth gate. Set to "false" to let anyone use opencorp without an account.
# In public mode, unauthenticated visitors share one research-sessions
# bucket owned by a seed auth user (see PUBLIC_BUCKET_USER_ID below).
# Auth pages and OAuth still work — they're just not required.
AUTH_ENABLED=true

# UUID of the seed auth.users row that owns all public-mode research
# sessions. Required only when AUTH_ENABLED=false. Create it once with:
#   pnpm seed:public-bucket
PUBLIC_BUCKET_USER_ID=

# ── Umami (cloud) ───────────────────────────────────────────────────────────
# Cloud site ID and tracker host. Find both in your Umami dashboard under
# the website's "Tracking code" panel.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_HOST_URL=